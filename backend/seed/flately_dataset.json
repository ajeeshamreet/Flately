  "messages": [
    {
      "id": "msg00000000000000000000001",
      "conversationId": "co000000000000000000000001",
      "senderId": "aaaaaaaaaaaaaaaaaaaaaaaa",
      "content": "Hey Vikram! Great to match. That composting setup sounds genuinely interesting — I've been trying to do the same in Bandra.",
      "createdAt": "2024-11-17T10:15:00.000Z"
    },
    {
      "id": "msg00000000000000000000002",
      "conversationId": "co000000000000000000000001",
      "senderId": "eeeeeeeeeeeeeeeeeeeeeeee",
      "content": "Hey! Small world, I'm in Bandra too. Do you have a preferred area? I have the room in a 2BHK near SV road, 20k all-in.",
      "createdAt": "2024-11-17T10:28:00.000Z"
    },
    {
      "id": "msg00000000000000000000003",
      "conversationId": "co000000000000000000000001",
      "senderId": "aaaaaaaaaaaaaaaaaaaaaaaa",
      "content": "That's right in my range. Can we do a quick call this evening and maybe visit over the weekend?",
      "createdAt": "2024-11-17T10:45:00.000Z"
    },
    {
      "id": "msg00000000000000000000004",
      "conversationId": "co000000000000000000000001",
      "senderId": "eeeeeeeeeeeeeeeeeeeeeeee",
      "content": "Absolutely! Saturday 11 AM works. I'll share the pin closer to the time.",
      "createdAt": "2024-11-17T11:00:00.000Z"
    },
    {
      "id": "msg00000000000000000000005",
      "conversationId": "co000000000000000000000002",
      "senderId": "bbbbbbbbbbbbbbbbbbbbbbbb",
      "content": "Hey Sneha! I noticed you play keyboard — I love Carnatic music. I'm an early bird though, so maybe we just need to sync on night practice timings 😄",
      "createdAt": "2024-11-17T11:25:00.000Z"
    },
    {
      "id": "msg00000000000000000000006",
      "conversationId": "co000000000000000000000002",
      "senderId": "dddddddddddddddddddddddd",
      "content": "Ha! Promise I use headphones after 9 PM. Where are you currently looking — HSR or Koramangala?",
      "createdAt": "2024-11-17T11:40:00.000Z"
    },
    {
      "id": "msg00000000000000000000007",
      "conversationId": "co000000000000000000000002",
      "senderId": "bbbbbbbbbbbbbbbbbbbbbbbb",
      "content": "Koramangala preferably, I work near Domlur. Budget is up to 18k.",
      "createdAt": "2024-11-17T11:55:00.000Z"
    },
    {
      "id": "msg00000000000000000000008",
      "conversationId": "co000000000000000000000003",
      "senderId": "ffffffffffffffffffffffffffff",
      "content": "Hi Pooja! Literally could not have found a better match — CA hours, clean kitchen, Marina runs? We're basically the same person.",
      "createdAt": "2024-11-17T16:15:00.000Z"
    },
    {
      "id": "msg00000000000000000000009",
      "conversationId": "co000000000000000000000003",
      "senderId": "mmmmmmmmmmmmmmmmmmmmmmmm",
      "content": "Haha exactly what I thought! Are you okay with Adyar or only central Chennai? I'm flexible on location.",
      "createdAt": "2024-11-17T16:30:00.000Z"
    },
    {
      "id": "msg00000000000000000000010",
      "conversationId": "co000000000000000000000003",
      "senderId": "ffffffffffffffffffffffffffff",
      "content": "Adyar works perfectly, I'm at Taramani. Should we shortlist some places on NoBroker together?",
      "createdAt": "2024-11-17T16:45:00.000Z"
    },
    {
      "id": "msg00000000000000000000011",
      "conversationId": "co000000000000000000000003",
      "senderId": "mmmmmmmmmmmmmmmmmmmmmmmm",
      "content": "Yes! I have 3 options bookmarked. Sending screenshots now.",
      "createdAt": "2024-11-17T17:00:00.000Z"
    },
    {
      "id": "msg00000000000000000000012",
      "conversationId": "co000000000000000000000004",
      "senderId": "nnnnnnnnnnnnnnnnnnnnnnnn",
      "content": "Hey Rahul! A researcher and a music producer under one roof — that's either a disaster or a masterpiece.",
      "createdAt": "2024-11-18T09:45:00.000Z"
    },
    {
      "id": "msg00000000000000000000013",
      "conversationId": "co000000000000000000000004",
      "senderId": "pppppppppppppppppppppppp",
      "content": "Ha, I like the odds. Headphones are a sacred covenant in my flat. Tell me about the room you're looking for — budget and area?",
      "createdAt": "2024-11-18T10:00:00.000Z"
    },
    {
      "id": "msg00000000000000000000014",
      "conversationId": "co000000000000000000000004",
      "senderId": "nnnnnnnnnnnnnnnnnnnnnnnn",
      "content": "Around 10-12k, okay with south Kolkata. Is the room in your flat available from December?",
      "createdAt": "2024-11-18T10:15:00.000Z"
    },
    {
      "id": "msg00000000000000000000015",
      "conversationId": "co000000000000000000000004",
      "senderId": "pppppppppppppppppppppppp",
      "content": "Available from December 1st. 11k all-in including wifi. Come take a look this Sunday?",
      "createdAt": "2024-11-18T10:30:00.000Z"
    }
  ]
