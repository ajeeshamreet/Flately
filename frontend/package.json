    "react-dom": "19.2.3",
    "react-hook-form": "7.71.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "socket.io-client": "4.8.3",
    "tailwind-merge": "^3.4.0",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
